{
  "version": 2,
  "builds": [
    {
      "src": "ssv-react/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "ssv-react/api/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/uploads/(.*)", "dest": "ssv-react/api/server.js" },
    { "src": "/api/(.*)",     "dest": "ssv-react/api/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)",         "dest": "/index.html" }
  ]
}
