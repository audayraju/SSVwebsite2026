{
  "buildCommand": "cd ssv-react && npm install && npm run build",
  "outputDirectory": "ssv-react/dist",
  "rewrites": [
    { "source": "/api/:path*",     "destination": "/api/server" },
    { "source": "/uploads/:path*", "destination": "/api/server" },
    { "source": "/(.*)",           "destination": "/index.html" }
  ]
}
